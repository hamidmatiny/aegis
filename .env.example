# AEGIS local development environment
# Copy to .env and adjust as needed

# Postgres
POSTGRES_USER=aegis
POSTGRES_PASSWORD=aegis_dev
POSTGRES_DB=aegis
DATABASE_URL=postgres://aegis:aegis_dev@postgres:5432/aegis?sslmode=disable

# Redis
REDIS_URL=redis://redis:6379/0

# Audit signing (Ed25519 — generate with: openssl genpkey -algorithm Ed25519 -out audit.key)
# Leave unset to use docker-compose dev default (stable across restarts). Empty string generates a new ephemeral key each restart.
AEGIS_AUDIT_URL=http://localhost:8084
# AEGIS_AUDIT_SIGNING_KEY=YWVnaXMtZGV2LWF1ZGl0LXNpZ25pbmcta2V5LXYxISE=

# SDK / gateway reverse-proxy (OpenAI-compatible entry on port 8080)
AEGIS_INPUT_DEFENSE_URL=http://localhost:8090
AEGIS_OUTPUT_DEFENSE_URL=http://localhost:8091
AEGIS_POLICY_ENGINE_URL=http://localhost:8081
AEGIS_MODEL_ROUTER_URL=http://localhost:8082
AEGIS_AGENT_GATE_URL=http://localhost:8083
# OPENAI_BASE_URL=http://localhost:8080/v1
AEGIS_AUDIT_SIGNING_KEY_ID=dev-key-1

# Service ports (host mapping)
GATEWAY_HTTP_PORT=8080
GATEWAY_GRPC_PORT=9080
POLICY_ENGINE_PORT=8081
MODEL_ROUTER_PORT=8082
AGENT_GATE_PORT=8083
AUDIT_PORT=8084
DASHBOARD_PORT=3000
INPUT_DEFENSE_PORT=8090
OUTPUT_DEFENSE_PORT=8091
REDTEAM_PORT=8092

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=aegis-gateway
LOG_LEVEL=info

# LLM providers (used by model-router — injected via docker-compose env_file, NOT baked into images)
# Set each key exactly once here. Do NOT export these in your shell; shell env overrides .env for compose.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Output-defense backends (compose defaults: toxicity=stub, pii=regex, backtranslation=router)
AEGIS_OUTPUT_DEFENSE_BACKTRANSLATION_BACKEND=router
AEGIS_OUTPUT_DEFENSE_BACKTRANSLATION_PROVIDER=grok
AEGIS_OUTPUT_DEFENSE_BACKTRANSLATION_MODEL=grok-4.3
AEGIS_OUTPUT_DEFENSE_JUDGE_PROVIDER=grok
AEGIS_OUTPUT_DEFENSE_JUDGE_MODEL=grok-4.3
AEGIS_REDTEAM_INPUT_DEFENSE_URL=http://localhost:8090
AEGIS_REDTEAM_OUTPUT_DEFENSE_URL=http://localhost:8091
AEGIS_REDTEAM_DETECTION_THRESHOLD=0.50

# Agent gate
AEGIS_POLICY_ENGINE_URL=http://localhost:8081
AEGIS_APPROVAL_TTL_HOURS=24

# Policy
AEGIS_DEFAULT_POLICY_PACK=default
AEGIS_POLICY_DIR=/etc/aegis/policies
