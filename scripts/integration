#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
COMPOSE="docker compose -f $ROOT/docker-compose.yml"

echo "==> Waiting for services to be healthy..."
$COMPOSE ps

echo "==> Running integration smoke tests..."
# Stage 0: verify health endpoints respond
services=(
  "http://localhost:8080/health|gateway"
  "http://localhost:8081/health|policy-engine"
  "http://localhost:8082/health|model-router"
  "http://localhost:8083/health|agent-gate"
  "http://localhost:8084/health|audit"
  "http://localhost:8090/health|input-defense"
  "http://localhost:8091/health|output-defense"
  "http://localhost:8092/health|redteam"
  "http://localhost:3000/|dashboard"
)

DASHBOARD_AUTH=()
if [[ -n "${AEGIS_DASHBOARD_PASSWORD:-changeme}" ]]; then
  DASHBOARD_AUTH=(-u "${AEGIS_DASHBOARD_USER:-admin}:${AEGIS_DASHBOARD_PASSWORD:-changeme}")
fi

for entry in "${services[@]}"; do
  url="${entry%%|*}"
  name="${entry##*|}"
  echo "  Checking $name at $url"
  if [[ "$name" == "dashboard" ]]; then
    curl -sf "${DASHBOARD_AUTH[@]}" "$url" > /dev/null || { echo "FAIL: $name"; exit 1; }
  else
    curl -sf "$url" > /dev/null || { echo "FAIL: $name"; exit 1; }
  fi
done

echo "==> Policy engine input evaluation smoke test..."
curl -sf -X POST http://localhost:8081/v1/evaluate/input \
  -H 'Content-Type: application/json' \
  -d '{"tenant_id":"default","input_verdict":{"action":"BLOCK","fused_score":0.92,"detector_scores":[{"detector_id":"heuristic","score":0.92,"reasoning":"test"}]}}' \
  | grep -q '"action":"block"' || { echo "FAIL: policy-engine evaluate/input"; exit 1; }

echo "==> Model router chat completion smoke test..."
curl -sf -X POST http://localhost:8082/v1/chat/completions \
  -H 'Content-Type: application/json' \
  -d '{"messages":[{"role":"user","content":"Hello"}]}' \
  | grep -q '"object":"chat.completion"' || { echo "FAIL: model-router chat/completions"; exit 1; }

echo "==> Go gateway defended chat smoke test..."
curl -sf -X POST http://localhost:8080/v1/chat/completions \
  -H 'Content-Type: application/json' \
  -d '{"model":"mock-model","messages":[{"role":"user","content":"Hello"}]}' \
  | grep -q '"object":"chat.completion"' || { echo "FAIL: gateway chat/completions"; exit 1; }

echo "==> All integration smoke tests passed"
