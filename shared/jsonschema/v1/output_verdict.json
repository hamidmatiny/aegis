{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.dev/schemas/v1/output_verdict.json",
  "title": "OutputVerdict",
  "description": "Fused output from all output defense detectors",
  "type": "object",
  "required": ["action", "fused_score", "detector_scores"],
  "properties": {
    "trace": { "$ref": "common.json#/$defs/TraceContext" },
    "action": { "$ref": "common.json#/$defs/VerdictAction" },
    "fused_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "detector_scores": {
      "type": "array",
      "items": { "$ref": "common.json#/$defs/DetectorScore" }
    },
    "redacted_content": { "type": "string" },
    "escalation_reason": { "type": "string" },
    "judge_votes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "judge_id": { "type": "string" },
          "prompt_framing": { "type": "string" },
          "vote": { "$ref": "common.json#/$defs/VerdictAction" },
          "reasoning": { "type": "string" },
          "latency_ms": { "type": "integer" }
        }
      }
    },
    "evaluated_at": { "type": "string", "format": "date-time" },
    "total_latency_ms": { "type": "integer", "minimum": 0 }
  }
}
